DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>?schema=public
JWT_SECRET=<strong_random_secret>

BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<smtp_user>
SMTP_PASS=<smtp_password>
SMTP_FROM=PlantSwap

PLANTNET_API_KEY=<plantnet_api_key>
PLANTNET_BASE_URL=https://my-api.plantnet.org/v2/species
PLANTNET_LANG=en
PLANTNET_TYPE=kt
PLANTNET_PAGE_SIZE=100
PLANTNET_PAGE=1
PLANTNET_INCLUDE_IMAGES=false

PLANT_ID_API_KEY=<plant_id_api_key>
PLANT_ID_BASE_URL=https://api.plant.id/v3/identification
PLANT_ID_AUTH_HEADER=Api-Key
PLANT_ID_AUTH_SCHEME=

DEEPL_API_KEY=<deepl_api_key>

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
AWS_S3_BUCKET_NAME=<s3_bucket_name>
AWS_S3_PUBLIC_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com
